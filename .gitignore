# Byte-compiled / cache
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/

# Runtime database (created by init_db() on first run)
rimai.db
*.db

# Trained model artifacts (regenerated automatically by train_yield_model()
# every time the app starts — not meant to be version controlled)
models/*.pkl

# Data pipeline outputs (regenerated by fetch_faostat.py / build_master_dataset.py /
# backtest_yield_model.py / synthetic_registry.py — keep the folders, not their contents)
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep

# Environment / secrets
.env
*.env
venv/
.venv/

# OS / editor cruft
.DS_Store
.vscode/
.idea/
