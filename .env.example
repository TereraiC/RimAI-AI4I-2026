# Copy this file to .env and fill in real values, or export these as
# environment variables directly. Everything here is optional — RimAI
# runs in a fully-functional, clearly-logged demo mode without any of
# these set (see README.md "Optional: live WhatsApp / email alerts").

# Twilio WhatsApp alerting
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# SMTP email alerting
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=
EMAIL_SMTP_PASSWORD=
EMAIL_FROM=
